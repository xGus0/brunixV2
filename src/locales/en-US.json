{
    "commands": {
        "play": {
            "description": "🎵 Plays a song or adds it to the queue",
            "options": {
                "query": "Song name or URL"
            },
            "responses": {
                "added_to_queue": "Added to queue: **{title}** [{duration}]",
                "playlist_added": "Added **{count}** songs from playlist **{name}** to the queue!",
                "no_results": "No results found for your search.",
                "starting": "Starting playback..."
            }
        },
        "search": {
            "description": "🔍 Searches for songs and displays results",
            "options": {
                "query": "Song name to search"
            },
            "responses": {
                "no_results": "No results found.",
                "select_placeholder": "Select a song..."
            }
        },
        "pause": {
            "description": "⏸️ Pauses the current song",
            "responses": {
                "paused": "Song paused!",
                "already_paused": "The song is already paused!"
            }
        },
        "resume": {
            "description": "▶️ Resumes the paused song",
            "responses": {
                "resumed": "Playback resumed!",
                "not_paused": "The song is not paused!"
            }
        },
        "skip": {
            "description": "⏭️ Skips to the next song",
            "responses": {
                "skipped": "Skipping **{title}**",
                "next": "Next: **{title}**",
                "no_next": "No more songs in the queue."
            }
        },
        "stop": {
            "description": "⏹️ Stops the music and disconnects",
            "responses": {
                "stopped": "Playback stopped and bot disconnected!"
            }
        },
        "queue": {
            "description": "📋 Shows the music queue",
            "responses": {
                "empty": "No songs in the queue!",
                "title": "Music Queue"
            }
        },
        "volume": {
            "description": "🔊 Adjusts the volume",
            "options": {
                "level": "Volume level (0-100)"
            },
            "responses": {
                "changed": "Volume changed from **{previous}%** to **{current}%**"
            }
        },
        "loop": {
            "description": "🔁 Sets the repeat mode",
            "options": {
                "mode": "Repeat mode"
            },
            "modes": {
                "none": "Disabled",
                "track": "Current Song",
                "queue": "Full Queue"
            },
            "responses": {
                "none": "Repeat mode disabled!",
                "track": "Repeating current song!",
                "queue": "Repeating entire queue!"
            }
        },
        "nowplaying": {
            "description": "🎶 Shows the currently playing song",
            "responses": {
                "title": "Now Playing",
                "no_music": "No music is currently playing."
            }
        },
        "shuffle": {
            "description": "🔀 Shuffles the music queue",
            "responses": {
                "shuffled": "Queue shuffled successfully!",
                "empty": "The queue is empty!"
            }
        },
        "lyrics": {
            "description": "📝 Shows the lyrics of the current song",
            "options": {
                "query": "Song name (optional)"
            },
            "responses": {
                "fetching": "Fetching lyrics...",
                "not_found": "Lyrics not found for this song.",
                "no_music": "No music is playing. Use: `!lyrics <song>`"
            }
        },
        "radio": {
            "description": "📻 Starts 24/7 radio mode with music genre",
            "options": {
                "genre": "Music genre (pop, rock, jazz...)"
            },
            "responses": {
                "starting": "Starting {genre} radio...",
                "stopped": "Radio stopped.",
                "genre_changed": "Genre changed to: **{genre}**"
            }
        },
        "favorite": {
            "description": "💖 Manages your favorite songs",
            "options": {
                "action": "Action (add, remove, list)"
            },
            "responses": {
                "added": "Song added to favorites!",
                "removed": "Song removed from favorites.",
                "empty": "You don't have any favorite songs yet.",
                "list_title": "Your Favorite Songs"
            }
        },
        "playlist": {
            "description": "📁 Manages your custom playlists",
            "options": {
                "action": "Action (create, delete, add, remove, list, play)"
            },
            "responses": {
                "created": "Playlist **{name}** created!",
                "deleted": "Playlist **{name}** deleted.",
                "empty": "You don't have any playlists.",
                "added": "Song added to playlist **{name}**!",
                "removed": "Song removed from playlist **{name}**.",
                "playing": "Playing playlist **{name}**..."
            }
        },
        "profile": {
            "description": "👤 Shows user profile",
            "options": {
                "user": "User (optional)"
            },
            "responses": {
                "title": "{username}'s Profile",
                "stats": "Statistics",
                "total_songs": "Total Songs",
                "total_time": "Total Time",
                "favorites": "Favorites",
                "playlists": "Playlists"
            }
        },
        "ping": {
            "description": "🏓 Shows bot latency",
